{
  "name": "Wiki2Ban",
  "author": "[https://www.lucamauri.com/ Luca Mauri]",
  "url": "https://github.com/lucamauri/Wiki2Ban",
  "descriptionmsg": "wiki2ban-desc",
  "version": "1.0",
  "license-name": "GPL-2.0-or-later",
  "type": "other",
  "manifest_version": 2,
  "AutoloadClasses": {
    "Wiki2BanHooks": "Wiki2Ban.php"
  },
  "Hooks": {
    "AuthManagerLoginAuthenticateAudit": "Wiki2BanHooks::onAuthManagerLoginAuthenticateAudit"
  },
  "config": {
    "W2BLogFilePath": {
      "description": "Path to the log file read by Fail2Ban. The web server process must have write permission to this file.",
      "value": "/var/log/mediawiki/wiki2ban.log"
    }
  },
  "MessagesDirs": {
    "Wiki2Ban": ["i18n"]
  },
  "requires": {
    "MediaWiki": ">= 1.35.0",
    "platform": {
      "php": ">= 8.4"
    }
  }
}
